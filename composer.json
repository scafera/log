{
    "name": "scafera/log",
    "description": "Structured logging for the Scafera framework",
    "type": "symfony-bundle",
    "license": "MIT",
    "require": {
        "php": ">=8.4",
        "scafera/kernel": "^1.0 || dev-main",
        "psr/log": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.5"
    },
    "autoload": {
        "psr-4": {
            "Scafera\\Log\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Scafera\\Log\\Tests\\": "tests/"
        }
    }
}
